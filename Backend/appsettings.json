{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "rankoon"
  },
  "Discord": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5020/api/auth/callback",
    "Scopes": ["identify", "email"]
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "Rankoon",
    "Audience": "RankoonUsers",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000",
    "CallbackPath": "/auth/callback"
  }
}
