# MongoDB
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DATABASE_NAME=rankoon

# Discord OAuth and bot configuration
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token

# JWT signing key. Use a long, random value in real environments.
JWT_SECRET_KEY=replace_with_a_long_random_secret_key

# Frontend URL allowed by the backend CORS policy
FRONTEND_BASE_URL=http://localhost:4200

# The development redirect URI is configured in appsettings.Development.json:
# http://localhost:5020/api/auth/callback
