# Discord OAuth Configuration
DISCORD_CLIENT_ID=your_discord_client_id_here
# WICHTIG: Das Client Secret gehört NUR ins Backend! Niemals ins Frontend!

# Backend API Configuration
API_BASE_URL=http://localhost:3000/api
BACKEND_CALLBACK_URL=http://localhost:3000/auth/discord/callback
FRONTEND_CALLBACK_URL=http://localhost:4200/auth/callback

# Production URLs (for deployment)
# PRODUCTION_API_BASE_URL=https://your-api-domain.com/api
# PRODUCTION_BACKEND_CALLBACK_URL=https://your-api-domain.com/auth/discord/callback
# PRODUCTION_FRONTEND_CALLBACK_URL=https://your-domain.com/auth/callback
