# Required application secrets and services
MONGODB_CONNECTION_STRING=mongodb://mongo:27017
MONGODB_DATABASE_NAME=rankoon
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token
JWT_SECRET_KEY=replace_with_a_long_random_secret_key

# Public URL of this container. Both values must use the same public origin.
DISCORD_REDIRECT_URI=https://rankoon.example.com/api/auth/callback
FRONTEND_BASE_URL=https://rankoon.example.com

# Global voice XP reconciliation interval in seconds.
VOICEWATCHDOG__INTERVALSECONDS=5

CUSTOMBOTIDENTITY__ENABLED=false
CUSTOMBOTIDENTITY__MAXACTIVEGUILDS=10
CUSTOMBOTIDENTITY__FINGERPRINTKEY=replace_with_a_separate_long_random_secret
CUSTOMBOTIDENTITY__STARTUPPARALLELISM=2
# CUSTOMBOTIDENTITY__ALLOWEDGUILDIDS__0=123456789012345678
# CUSTOMBOTIDENTITY__ALLOWEDGUILDIDS__1=234567890123456789
DATAPROTECTION__KEYRINGPATH=/var/lib/rankoon/data-protection-keys
