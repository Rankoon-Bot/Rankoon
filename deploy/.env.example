# Required application secrets and services
MongoDb__ConnectionString=mongodb://mongo:27017
MongoDb__DatabaseName=rankoon
Discord__ClientId=your_discord_application_client_id
Discord__ClientSecret=your_discord_application_client_secret
Discord__BotToken=your_discord_bot_token
Jwt__SecretKey=replace_with_a_long_random_secret_key

# Public URL of this container. Both values must use the same public origin.
Discord__RedirectUri=https://rankoon.example.com/api/auth/callback
Frontend__BaseUrl=https://rankoon.example.com
